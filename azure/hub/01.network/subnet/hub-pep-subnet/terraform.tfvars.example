# terraform.tfvars.example
#
# 사용법:
#   1) 이 파일을 terraform.tfvars로 복사
#   2) <PLACEHOLDER> 부분을 실제 값으로 교체
#   3) hub_subscription_id, spoke_subscription_id는 본 파일에 두지 않음 —
#      환경변수로 주입: export TF_VAR_hub_subscription_id=...
#                       export TF_VAR_spoke_subscription_id=...
#   4) backend 설정은 별도 backend.hcl 파일을 사용:
#      terraform init -backend-config=backend.hcl
#
# Hub Subnet/NSG 리프 — vnet/hub-vnet 이후 적용
project_name  = "test"
environment   = "dev"
location      = "Korea Central"

tags = {
  Environment = "dev"
  ManagedBy   = "Terraform"
}


# backend_resource_group_name  = "..."
# backend_storage_account_name = "..."
# backend_container_name       = "tfstate"

# securitygroup/hub 선행 시 ASG·standalone NSG ID를 그 state에서 읽음
# use_securitygroup_prereq = true

# enable_keyvault_sg = true
# hub_subnet_names_attach_keyvault_sg = []
# hub_nsg_keys_add_keyvault_rule = ["monitoring_vm"]
# enable_pe_inbound_from_asg = true
# keyvault_clients_asg_name = "keyvault-clients-asg"

# enable_vm_access_sg = true
# vm_access_target_nsg_keys = ["monitoring_vm"]
# vm_access_destination_ports = ["22", "3389"]

hub_backend_resource_group_name  = "terraform-state-rg"
hub_backend_storage_account_name = "tfstatea9911"
hub_backend_container_name       = "tfstate"
