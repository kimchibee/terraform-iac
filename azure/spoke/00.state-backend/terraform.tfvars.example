# azure/spoke/00.state-backend tfvars
# `cp terraform.tfvars.example terraform.tfvars` 후 spoke_subscription_id 입력.
# `*.tfvars` 는 .gitignore 대상.

# 필수: Spoke 구독 ID — 이 구독에 spoke state SA 가 생성됨
spoke_subscription_id = "20e3a0f3-f1af-4cc5-8092-dc9b276a9911"

# 아래는 모두 기본값. 다른 값이 필요할 때만 주석 해제:
#
# location              = "Korea Central"
# resource_group_name   = "terraform-state-spoke-rg"
#
# storage_account_name 은 글로벌 unique. 기본값 충돌 시 다른 이름으로 변경하고
# 모든 Spoke leaf 의 tfvars 의 spoke_backend_storage_account_name 도 같은 값으로 맞출 것.
# storage_account_name  = "tfstatespka9911"
#
# container_name         = "tfstate"
# enable_blob_versioning = true
#
# tags = {
#   ManagedBy = "Terraform"
#   Purpose   = "tfstate"
#   Side      = "spoke"
# }
