# terraform.tfvars.example
#
# 사용법:
#   1) 이 파일을 terraform.tfvars로 복사
#   2) <PLACEHOLDER> 부분을 실제 값으로 교체
#   3) hub_subscription_id, spoke_subscription_id는 본 파일에 두지 않음 —
#      환경변수로 주입: export TF_VAR_hub_subscription_id=...
#                       export TF_VAR_spoke_subscription_id=...
#   4) backend 설정은 별도 backend.hcl 파일을 사용:
#      terraform init -backend-config=backend.hcl
#
#--------------------------------------------------------------
# AI Services Stack Variables
#--------------------------------------------------------------

# General
project_name = "test"
environment  = "dev"
location     = "Korea Central"

tags = {
  Environment = "dev"
  ManagedBy   = "Terraform"
  Project     = "Azure-Hub-Spoke"
}

# Subscription

# Backend (Bootstrap의 terraform.tfvars와 동일하게 맞출 것)

# ---------------------------------------------------------------------------
# Azure OpenAI 모델 배포 — 쿼터 승인 전에는 비활성화(빈 목록), 승인 후 수정 필요
# ---------------------------------------------------------------------------
# 쿼터가 없으면 모델 배포를 생성할 수 없으므로, 승인 후 재시도 시 아래를 수정합니다.
# 1) openai_deployments = [] 를 제거하고
# 2) 아래 중 사용할 모델 블록의 주석을 해제한 뒤 name/model_name/version/capacity 설정
# 쿼터 확인: az cognitiveservices usage list --location koreacentral -o table
# 쿼터 요청: https://aka.ms/oai/stuquotarequest
# 상세: docs/AZURE-OPENAI-QUOTA-AND-MODELS.md
# ---------------------------------------------------------------------------
openai_sku = "S0"
openai_deployments = []
# AI Foundry/Private Endpoint (default true)
enable_ai_foundry_workspace = true
enable_private_endpoints    = true
# 승인 후 재시도 시 아래 중 하나 주석 해제 후 사용. 나중에 수정 필요.
# openai_deployments = [
#   { name = "gpt-4o",       model_name = "gpt-4o",       version = "2024-05-13", capacity = 30 }
#   { name = "gpt-4o-mini", model_name = "gpt-4o-mini", version = "2024-07-18", capacity = 10 }
#   { name = "gpt-35-turbo", model_name = "gpt-35-turbo", version = "0613",     capacity = 10 }
# ]

hub_backend_resource_group_name  = "terraform-state-rg"
hub_backend_storage_account_name = "tfstatea9911"
hub_backend_container_name       = "tfstate"

spoke_backend_resource_group_name  = "<SPOKE_STATE_RG>"
spoke_backend_storage_account_name = "<SPOKE_STATE_STORAGE_ACCOUNT>"
spoke_backend_container_name       = "tfstate"
