#--------------------------------------------------------------
# Compute 루트 변수 예시
# cp terraform.tfvars.example terraform.tfvars 후 수정
# 리소스별 정보(VM 이름 접미사, 사이즈, OS 등)는 각 하위 폴더(linux-monitoring-vm, windows-example)의 variables.tf 기본값에서 관리.
# 루트에는 공통·컨텍스트·Windows 비밀번호만 둠.
#--------------------------------------------------------------

project_name = "test"
environment  = "dev"
location     = "Korea Central"

tags = {
  Environment = "dev"
  ManagedBy   = "Terraform"
  Project     = "Azure-Hub-Spoke"
}

hub_subscription_id   = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
spoke_subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Backend (Bootstrap의 terraform.tfvars와 동일하게 맞출 것)
backend_resource_group_name  = "terraform-state-rg"
backend_storage_account_name = "tfstate07dc60"
backend_container_name       = "tfstate"

# 방화벽 정책(ASG): 모든 VM에 공통 적용. 필요 시 ["keyvault_clients"], ["vm_allowed_clients"] 등으로 변경
# application_security_group_keys = ["keyvault_clients", "vm_allowed_clients"]

# Windows VM 비밀번호만 루트에서 설정 (보안상 저장소에 올리지 말 것). Linux VM은 SSH 키로 인증
windows_example_admin_password = "CHANGE_ME_StrongP@ssw0rd!"
