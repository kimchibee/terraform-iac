#--------------------------------------------------------------
# RBAC Stack Variables
# compute 스택 적용 후 실행. Monitoring VM identity에 역할 부여
#--------------------------------------------------------------

project_name = "test"
environment  = "dev"

tags = {
  Environment = "dev"
  ManagedBy   = "Terraform"
  Project     = "Azure-Hub-Spoke"
}

hub_subscription_id   = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
spoke_subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Backend (Bootstrap의 terraform.tfvars와 동일하게 맞출 것)
backend_resource_group_name  = "terraform-state-rg"
backend_storage_account_name = "tfstate07dc60"
backend_container_name       = "tfstate"

# compute 스택에서 Monitoring VM 사용 시 true. VM 비활성화 시 역할도 생성하지 않음
enable_monitoring_vm_roles = true
enable_key_vault_roles     = true

#--------------------------------------------------------------
# 시나리오 1: 그룹 기반 리소스 권한 (관리자 그룹 / AI 개발자 그룹)
# Azure AD(Entra ID)에서 그룹 생성 후 Object ID를 복사. 멤버십은 Terraform으로 등록/변경/삭제.
#--------------------------------------------------------------
# 관리자 그룹
# admin_group_object_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# admin_group_scope_id  = "/subscriptions/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# 역할 이름 — admin-group 폴더 variables.tf 기본값에서 관리
# admin_group_member_object_ids = ["user-or-group-object-id-1", "user-or-group-object-id-2"]

# AI 개발자 그룹
# ai_developer_group_object_id       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# Spoke RG 역할 — ai-developer-group 폴더 variables.tf 기본값에서 관리
# ai_developer_group_member_object_ids = ["user-or-group-object-id-1"]

#--------------------------------------------------------------
# 시나리오 2: 리소스별 IAM 역할 할당 (추가/변경/삭제는 목록 수정 후 apply)
# scope_ref: storage_key_vault_id, ai_services_openai_id, ai_services_key_vault_id, ai_services_storage_id, network_hub_rg_id, network_spoke_rg_id, apim_id
# scope_ref 없으면 scope에 ARM 리소스 ID 전체 입력.
# use_spoke_provider = true → Spoke 구독 리소스 (APIM, ai_services 등). false → Hub 구독 (storage Key Vault 등).
#--------------------------------------------------------------
# iam_role_assignments = [
#   # Hub: Key Vault
#   { principal_id = "user-or-mi-object-id", role_definition_name = "Key Vault Secrets User", scope_ref = "storage_key_vault_id", use_spoke_provider = false },
#   # Spoke: OpenAI
#   { principal_id = "xxx", role_definition_name = "Cognitive Services User", scope_ref = "ai_services_openai_id", use_spoke_provider = true },
#   # Spoke: APIM (APIM은 Spoke 구독에 있으므로 use_spoke_provider = true)
#   { principal_id = "yyy", role_definition_name = "API Management Service Contributor Role", scope_ref = "apim_id", use_spoke_provider = true },
# ]
