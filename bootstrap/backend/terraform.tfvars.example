#--------------------------------------------------------------
# Bootstrap Backend Variables
# 이 파일을 terraform.tfvars로 복사하여 사용
# 구독·VNet 연동: docs/TERRAFORM_GUIDE.md "구독·VNet·Backend 연동 네이밍 규칙" 참고
#--------------------------------------------------------------
# [필수 수정] storage_account_name 은 전역 고유 리소스입니다.
#   - Azure 전체(모든 구독·테넌트)에서 이름이 유일해야 하며, 다른 사람이 쓰는 이름과 겹치면 생성 실패합니다.
#   - 규칙: 소문자·숫자만, 3~24자, 하이픈(-) 사용 불가.
#   - 레포를 다운받은 사용자는 반드시 본인만의 고유명으로 변경하세요.
#   - 추천: "tfstate" + 구독ID 뒤 6자리 (예: tfstate07dc60), 또는 "tfstate" + 프로젝트/팀 약어 + 숫자.
#   - container_name, resource_group_name 은 구독 내에서만 유일하면 되므로 하이픈 사용 가능.
#--------------------------------------------------------------
# 네이밍 예시 (project=kimchibee, env=test, 구독 ID 뒤 6자=07dc60):
#   resource_group_name  = "kimchibee-test-tfstate-rg"
#   storage_account_name = "tfstate07dc60"   # 전역 고유명 (소문자·숫자 3~24자). 반드시 수정.
#   container_name       = "tfstate"
#--------------------------------------------------------------

resource_group_name  = "terraform-state-rg"
storage_account_name = "tfstate07dc60"  # [수정 필수] 전역 고유명으로 변경 (소문자·숫자 3~24자)
container_name       = "tfstate"
location             = "Korea Central"

# Optional
# subnet_id = "/subscriptions/.../resourceGroups/.../providers/Microsoft.Network/virtualNetworks/.../subnets/..."

tags = {
  ManagedBy = "Terraform"
  Purpose   = "Terraform-Backend"
}
