#--------------------------------------------------------------
# Storage Stack Variables
# terraform.tfvars.example을 복사하여 terraform.tfvars 생성
#--------------------------------------------------------------

# General
project_name = "test"
environment  = "dev"
location     = "Korea Central"

tags = {
  Environment = "dev"
  ManagedBy   = "Terraform"
  Project     = "Azure-Hub-Spoke"
}

# Subscription
hub_subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Backend (Bootstrap의 terraform.tfvars와 동일하게 맞출 것)
backend_resource_group_name  = "terraform-state-rg"
backend_storage_account_name = "tfstate07dc60"
backend_container_name       = "tfstate"

# Key Vault / Monitoring VM — monitoring-storage 폴더 variables.tf 기본값에서 관리 (수정 시 해당 폴더만 편집)
# monitoring_vm_identity_principal_id = ""  # compute 스택 배포 후 필요 시 루트 tfvars에 fallback 설정
